# Karen — single source of truth.
# Copy to .env (gitignored), fill in, then run ./setup.sh once.
# The number of APPLE_ID_N / APPLE_PASS_N pairs decides how many
# wrapper-manager instances are created — add or remove pairs and
# re-run ./setup.sh to scale. STOREFRONT is fixed to "us" in the
# generated config and intentionally not exposed here.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=""
# Comma-separated chat IDs allowed to use the bot. E.g. "-100123456789,-100987654321"
TELEGRAM_ALLOWED_CHAT_IDS=""
# Comma-separated user IDs with admin/sudo privileges. E.g. "111111111,222222222"
ADMIN_IDS=""

# --- Apple Music ---
# media-user-token from browser devtools on music.apple.com
MEDIA_USER_TOKEN=""

# --- Multi-account upload (Phase 1, optional) ---
# Comma-separated helper bot tokens (one per @BotFather bot). Each one
# parallelizes uploads to the dump channel. Empty = disabled → single-account
# upload path (today's behavior). E.g. "123:AAA,456:BBB"
HELPER_BOT_TOKENS=""
# Private dump channel that physically stores uploaded media. The main bot AND
# every helper bot must be admins (post + read history). Bot API -100… id.
DUMP_CHANNEL_ID=0

# --- Optional ---
GOFILE_TOKEN=""
# Supabase (Singapore) pooled Postgres connection string for the Phase 2
# read-through catalog. Empty = catalog disabled → every request rips as today.
# Secret. e.g. postgresql://postgres.<ref>:<pw>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=""
# Mid-rip flush: once a rip's files on disk exceed this many GB, that chunk is
# zipped, uploaded to Gofile (as "… (Part N).zip"), and deleted to free disk
# before the rip continues. Keeps huge discographies from filling the VPS.
# Unset/omit = 20GB default. Set negative to disable.
RIP_FLUSH_THRESHOLD_GB=20

# --- Apple Music accounts ---
# One id/pass pair per wrapper-manager instance. Number them sequentially
# starting at 1, with no gaps. Add APPLE_ID_3 / APPLE_PASS_3, etc. to scale up.
APPLE_ID_1=""
APPLE_PASS_1=""
APPLE_ID_2=""
APPLE_PASS_2=""
